# ============ AI 提供商配置 ============
# 选择 AI 提供商: gemini | openai (openai 兼容 DeepSeek、OpenAI、Groq、Together 等)
VITE_AI_PROVIDER=gemini

# API 密钥 (必填)
VITE_AI_API_KEY=your-api-key-here

# ---- Gemini 配置 (默认) ----
# 无需设置 BASE_URL，默认模型: gemini-2.5-pro-preview-05-06 / gemini-2.0-flash

# ---- OpenAI 配置 ----
# VITE_AI_PROVIDER=openai
# VITE_AI_API_KEY=sk-xxx
# VITE_AI_BASE_URL=https://api.openai.com/v1
# VITE_AI_MODEL=gpt-4o
# VITE_AI_MODEL_LIGHT=gpt-4o-mini

# ---- DeepSeek 配置 ----
# VITE_AI_PROVIDER=openai
# VITE_AI_API_KEY=sk-xxx
# VITE_AI_BASE_URL=https://api.deepseek.com
# VITE_AI_MODEL=deepseek-chat
# VITE_AI_MODEL_LIGHT=deepseek-chat

# ---- Groq 配置 ----
# VITE_AI_PROVIDER=openai
# VITE_AI_API_KEY=gsk_xxx
# VITE_AI_BASE_URL=https://api.groq.com/openai/v1
# VITE_AI_MODEL=llama-3.3-70b-versatile
# VITE_AI_MODEL_LIGHT=llama-3.3-70b-versatile

# ---- 兼容旧配置 ----
# VITE_GEMINI_API_KEY=your-gemini-key (如果未设置 VITE_AI_API_KEY，会回退到此变量)

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
